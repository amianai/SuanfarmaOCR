# Copia questo file in ".env" e imposta i valori reali.
# Il file ".env" è escluso da git: i segreti NON finiscono mai su GitHub.
#
#   cp .env.example .env      # poi modifica i valori qui sotto

# --- Cartella dati ---
# Dove si trovano archivio.db, documenti_pdf/, testo_estratto/ e l'Excel.
# Scaricali dal Drive del progetto e fai puntare qui DATA_DIR.
# Se lasciato vuoto, usa la cartella del progetto (comodo in sviluppo locale).
DATA_DIR=/percorso/alla/cartella/dati

# --- Autenticazione (backend FastAPI) ---
# Genera un segreto robusto: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=metti-qui-un-segreto-lungo-e-casuale
VIEWER_PASSWORD=scegli-una-password-di-consultazione
ADMIN_PASSWORD=scegli-una-password-admin

# --- OCR (Tesseract locale) ---
OCR_LANG=ita
OCR_DPI=300

# --- Chatbot RAG (modello LLM) ---
# Endpoint OpenAI-compatibile. In sviluppo: Ollama locale. In produzione: vLLM o API.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:3b
LLM_API_KEY=
# "openai" (generico, produzione) oppure "ollama" (nativo, per disattivare il
# "thinking" dei modelli che ragionano — l'endpoint OpenAI di Ollama lo ignora).
LLM_API_STYLE=openai

# NB: nessuna chiave di servizi esterni è necessaria — l'OCR è locale (Tesseract)
# e il modello di embedding gira in locale.
